{
  "name": "wupi",
  "version": "0.1.0",
  "private": true,
  "main": "electron-dist/main.js",
  "type": "module",
  "description": "Wupi - Next.js + Electron app",
  "author": "Pratham",
  "scripts": {
    "dev:next": "next dev",
    "dev:electron": "wait-on http://localhost:3000 && tsc -p tsconfig.electron.json && tsc -p tsconfig.preload.json && node -e \"require('fs').renameSync('electron-dist/preload.js','electron-dist/preload.cjs')\" && electron -r tsx/cjs electron/main.ts",
    "dev": "concurrently --kill-others \"bun run dev:next\" \"bun run dev:electron\"",
    "build:next": "next build && node -e \"require('fs').cpSync('.next/static', '.next/standalone/.next/static', {recursive: true})\" && node -e \"require('fs').cpSync('public', '.next/standalone/public', {recursive: true})\"",
    "build:electron": "tsc -p tsconfig.electron.json && tsc -p tsconfig.preload.json && node -e \"require('fs').renameSync('electron-dist/preload.js','electron-dist/preload.cjs')\"",
    "start:next": "next start -p 3000",
    "build": "npm run build:next && npm run build:electron && npx electron-builder",
    "start": "concurrently \"bun run start:next\" \"electron .\""
  },
  "build": {
    "appId": "xyz.prathambuilds.wupi",
    "files": [
      "electron-dist/**/*.js",
      "electron-dist/**/*.cjs",
      ".next/standalone/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      ".next/standalone/**/*"
    ],
    "win": {
      "signAndEditExecutable": false
    },
    "directories": {
      "output": "release"
    },
    "extraMetadata": {
      "type": "module"
    }
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.79.7",
    "@earendil-works/pi-coding-agent": "^0.79.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron-is-dev": "^3.0.1",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "radix-ui": "^1.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "wait-on": "^9.0.10"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25.9.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
